{
  "name": "ticket-system",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "fuser -k 3000/tcp 5000/tcp 2>/dev/null; concurrently --kill-others-on-fail \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0 --port 5000",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production PORT=5000 tsx server/index.ts",
    "db:push": "drizzle-kit push",
    "sync:github": "bash scripts/github-sync.sh",
    "sync:status": "bash scripts/sync-status.sh",
    "hooks:setup": "bash scripts/setup-git-hooks.sh"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.39.3",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tsx": "^4.21.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.30.6",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21"
  }
}
